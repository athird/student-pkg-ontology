

 
@prefix pkgf: <https://w3id.org/cupa/pkg/categories#> .
@prefix owl:  <http://www.w3.org/2002/07/owl#> .
@prefix rdf:  <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:  <http://www.w3.org/2001/XMLSchema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dct:  <http://purl.org/dc/terms/> .
 
 
pkgf: a owl:Ontology ;
  rdfs:label "CUPA PKG – Learning Personalisation Category Ontology (from spreadsheet)"@en ;
  dct:created "2026-01-30"^^xsd:date ;
  dct:description "Ontology generated from OU Analyse learning analytics machine-learning data model."@en .
 
pkgf:CategoryType a owl:Class ; rdfs:label "Category type"@en .
pkgf:PredictiveCategory a owl:Class ; rdfs:label "Predictive category"@en .
pkgf:Learner a owl:Class ; rdfs:label "Learner"@en .
 
pkgf:hasCategoryType a owl:ObjectProperty ;
  rdfs:label "has category type"@en ;
  rdfs:domain pkgf:PredictiveCategory ;
  rdfs:range  pkgf:CategoryType .
 
pkgf:realisedByProperty a owl:AnnotationProperty ;
  rdfs:label "realised by property"@en .
 
pkgf:sourceName a owl:AnnotationProperty ;
  rdfs:label "source name"@en .
 
pkgf:Recommender a pkgf:CategoryType ;
  skos:prefLabel "Recommender"@en .
 
pkgf:VLE a pkgf:CategoryType ;
  skos:prefLabel "VLE"@en .
 
pkgf:assessments a pkgf:CategoryType ;
  skos:prefLabel "assessments"@en .
 
pkgf:demographic a pkgf:CategoryType ;
  skos:prefLabel "demographic"@en .
 
pkgf:finance a pkgf:CategoryType ;
  skos:prefLabel "finance"@en .
 
pkgf:progression a pkgf:CategoryType ;
  skos:prefLabel "progression"@en .
 
### demographic / gender
pkgf:gender a pkgf:PredictiveCategory ;
  skos:prefLabel "gender"@en ;
  pkgf:sourceName "gender" ;
  pkgf:hasCategoryType pkgf:demographic ;
  pkgf:realisedByProperty pkgf:has_gender .
 
pkgf:has_gender a owl:DatatypeProperty ;
  rdfs:label "has_gender"@en ;
  rdfs:domain pkgf:Learner ;
  rdfs:comment "Datatype property corresponding to category 'gender' (range to be specialised using additional spreadsheet columns)."@en .
 
